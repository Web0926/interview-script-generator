# 把这个文件复制为 .env，然后填入你的 OpenRouter API Key
# 获取地址：https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-opus-4.6
PORT=3001

# ─── 微信小程序配置 ───────────────────────────────────
WX_APPID=wxXXXXXXXXXXXXXX
WX_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 微信支付配置（可选）─────────────────────────────
WX_MCH_ID=1234567890
WX_MCH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WX_PAY_NOTIFY_URL=https://your-domain.com/api/wx/pay/notify
